{
  "scripts": {
    "lint": "node ../../scripts/check-app-js.mjs web",
    "test": "npm run lint && npm run test:analytics && npm run test:spatial-file && npm run test:pipeline-graph && npm run test:viewer-controller && npm run test:result-display && npm run test:n4-shrink-policy",
    "test:analytics": "node --no-warnings scripts/test_analytics.mjs",
    "test:spatial-file": "node --no-warnings scripts/test_spatial_file.mjs",
    "test:pipeline-graph": "node --no-warnings scripts/test_pipeline_graph.mjs",
    "test:viewer-controller": "node --no-warnings scripts/test_viewer_controller.mjs",
    "test:result-display": "node --no-warnings scripts/test_result_display.mjs",
    "test:n4-shrink-policy": "node --no-warnings scripts/test_n4_shrink_policy.mjs",
    "vendor": "node ../../scripts/vendor-components.mjs",
    "runtime-support": "node ../../scripts/vendor-runtime-support.mjs",
    "predev": "pnpm vendor && pnpm runtime-support",
    "dev": "bash web/run.sh",
    "prebuild": "pnpm vendor && pnpm runtime-support && bash web/setup.sh",
    "build": "node ../../scripts/build-static.mjs",
    "pretest": "pnpm runtime-support",
    "pretest:e2e": "pnpm vendor && pnpm runtime-support",
    "test:e2e": "playwright test",
    "test:shared": "node --test test/shared-components-parity.test.js"
  },
  "dependencies": {
    "nifti-reader-js": "^0.8.0",
    "onnxruntime-node": "^1.24.3",
    "@neurodesk/webapp-components": "workspace:*"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "jsdom": "^24.0.0"
  },
  "name": "vesselboost",
  "version": "0.1.1",
  "private": true,
  "type": "module",
  "neurodeskWebapp": {
    "static": {
      "coiServiceWorker": true
    }
  }
}
